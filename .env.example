# App — el contenedor escucha en 3000; el host publica 3003 (gql.corecodeinnovation.com)
PORT=3000

# Postgres — dentro de compose se usa db:5432; desde el host en dev: localhost:5434
DATABASE_URL=postgresql://gql:gql@db:5432/gqlcore

# Auth — el JWT lo emite cci-auth-service; aquí solo se valida (RS256 vía JWKS)
AUTH_JWKS_URL=http://cci-auth-service:3000/.well-known/jwks.json
AUTH_ISSUER=cci-auth-service
# Solo dev/test: si se define, se valida HS256 con este secreto en lugar del JWKS
# AUTH_JWT_SECRET=un-secreto-de-desarrollo

# Guardrails — límites contra queries abusivas
GRAPHQL_MAX_DEPTH=8
GRAPHQL_MAX_COMPLEXITY=100
